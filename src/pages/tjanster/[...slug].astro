---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

import { companyConfig } from "../../config/company";
import { siteConfig } from "../../config/site";

import {
  generateGraph,
  getWebPage,
  getService,
  getFAQPage,
  getBreadcrumbs,
} from "../../utils/jsonLD";
import type { Thing } from "schema-dts";

export async function getStaticPaths() {
  const services = await getCollection("services");
  return services.map((entry) => ({
    params: { slug: entry.data.slug ?? entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Map slug → entry once, so we can resolve relatedServices safely
const allServices = await getCollection("services");
const relatedServices = entry.data.relatedServices
  ? entry.data.relatedServices
      .map((relSlug) =>
        allServices.find(
          (s) => (s.data.slug ?? s.slug) === relSlug,
        ),
      )
      .filter((s): s is NonNullable<typeof s> => Boolean(s))
  : [];

const pageTitle = `${entry.data.metaTitle ?? entry.data.title} | ${companyConfig.name}`;
const pageDescription = entry.data.metaDescription ?? entry.data.description;

const webpage = getWebPage(Astro.url.pathname, pageTitle, pageDescription);

const service = getService(Astro.url.pathname, {
  title: entry.data.title,
  description: entry.data.description,
  schemaType: entry.data.schemaType,
  image: entry.data.image,
  priceRange: entry.data.priceRange,
});

const breadcrumbs = getBreadcrumbs([
  { name: "Hem", pathname: "/" },
  { name: "Tjänster", pathname: "/tjanster" },
  { name: entry.data.title, pathname: Astro.url.pathname },
]);

const graphNodes: Thing[] = [webpage, service, breadcrumbs];

if (entry.data.faq && entry.data.faq.length > 0) {
  graphNodes.push(getFAQPage(entry.data.faq, Astro.url.pathname));
}

const schema = generateGraph(graphNodes);
---

<Layout
  title={pageTitle}
  description={pageDescription}
  image={entry.data.image}
  theme={siteConfig.theme}
  font={siteConfig.font}
  schema={schema}
>
  <Header />

  <main class="flex-grow bg-base-100 pb-20">
    <!-- Hero -->
    <header class="relative py-20 bg-base-200">
      <div
        class="max-w-[1400px] mx-auto px-4 md:px-10 grid md:grid-cols-2 gap-12 items-center"
      >
        <div>
          <nav
            class="text-sm text-base-content/60 mb-6"
            aria-label="Brödsmulor"
          >
            <a href="/" class="hover:text-primary decoration-0!">Hem</a>
            <span class="mx-2">/</span>
            <a href="/tjanster" class="hover:text-primary decoration-0!"
              >Tjänster</a
            >
            <span class="mx-2">/</span>
            <span class="text-base-content/80">{entry.data.title}</span>
          </nav>

          {
            entry.data.icon && (
              <div class="w-14 h-14 rounded-xl bg-primary text-primary-content flex items-center justify-center mb-6">
                <Icon name={entry.data.icon} class="w-7 h-7" />
              </div>
            )
          }

          <h1
            class="text-4xl md:text-5xl/tight font-extrabold mb-6 text-base-content"
          >
            {entry.data.title}
          </h1>

          <p class="text-xl text-base-content/70 mb-8 leading-relaxed">
            {entry.data.shortDescription}
          </p>

          <div class="flex flex-wrap gap-4 text-sm">
            {
              entry.data.priceRange && (
                <div class="flex items-center gap-2 px-4 py-2 bg-base-100 rounded-full border border-base-300">
                  <Icon
                    name="heroicons:banknotes"
                    class="w-4 h-4 text-primary"
                  />
                  <span class="font-medium text-base-content/80">
                    {entry.data.priceRange}
                  </span>
                </div>
              )
            }
            {
              entry.data.duration && (
                <div class="flex items-center gap-2 px-4 py-2 bg-base-100 rounded-full border border-base-300">
                  <Icon name="heroicons:clock" class="w-4 h-4 text-primary" />
                  <span class="font-medium text-base-content/80">
                    {entry.data.duration}
                  </span>
                </div>
              )
            }
          </div>
        </div>

        {
          entry.data.image && (
            <div class="relative group">
              <div class="absolute inset-0 bg-primary/10 rounded-2xl transform rotate-3 transition-transform group-hover:rotate-0 duration-500" />
              <img
                src={entry.data.image}
                alt={entry.data.imageAlt ?? entry.data.title}
                class="relative rounded-2xl shadow-2xl w-full aspect-[4/3] object-cover transform -rotate-1 transition-transform group-hover:rotate-0 duration-500"
              />
            </div>
          )
        }
      </div>
    </header>

    <!-- Content -->
    <article class="max-w-3xl mx-auto px-4 md:px-10 py-16">
      <div
        class="prose prose-lg prose-headings:font-bold prose-a:text-primary hover:prose-a:text-primary-focus"
      >
        <Content />
      </div>
    </article>

    <!-- FAQ -->
    {
      entry.data.faq && entry.data.faq.length > 0 && (
        <section class="bg-base-200 py-16">
          <div class="max-w-3xl mx-auto px-4 md:px-10">
            <h2 class="text-3xl font-bold text-base-content mb-10 text-center">
              Vanliga frågor om {entry.data.title.toLowerCase()}
            </h2>
            <div class="space-y-4">
              {entry.data.faq.map((item) => (
                <details class="collapse collapse-arrow bg-base-100 border border-base-200">
                  <summary class="collapse-title text-lg font-semibold">
                    {item.question}
                  </summary>
                  <div class="collapse-content text-base-content/70 leading-relaxed">
                    <p>{item.answer}</p>
                  </div>
                </details>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <!-- Related services -->
    {
      relatedServices.length > 0 && (
        <section class="py-16">
          <div class="max-w-[1400px] mx-auto px-4 md:px-10">
            <h2 class="text-2xl font-bold text-base-content mb-8">
              Relaterade tjänster
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              {relatedServices.map((rel) => {
                const relSlug = rel.data.slug ?? rel.slug;
                return (
                  <a
                    href={`/tjanster/${relSlug}`}
                    class="card bg-base-100 border border-base-200 hover:shadow-lg transition-all group decoration-0!"
                  >
                    <div class="card-body p-6">
                      <h3 class="font-bold text-base-content mb-2 group-hover:text-primary transition-colors">
                        {rel.data.title}
                      </h3>
                      <p class="text-sm text-base-content/70">
                        {rel.data.shortDescription}
                      </p>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        </section>
      )
    }

    <!-- CTA -->
    <section class="py-16 bg-base-100">
      <div class="max-w-3xl mx-auto px-4 md:px-10 text-center">
        <h2 class="text-3xl font-bold text-base-content mb-4">
          Vill du veta mer?
        </h2>
        <p class="text-base-content/70 mb-8">
          {`Kontakta ${companyConfig.name} så hjälper vi dig vidare.`}
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a
            href="/#kontakt"
            class="btn btn-primary"
          >
            Kontakta oss
          </a>
          <a href="/tjanster" class="btn btn-outline gap-2 group">
            <Icon
              name="heroicons:chevron-left"
              class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform"
            />
            Alla tjänster
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
