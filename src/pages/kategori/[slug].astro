---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import ArticleList from "../../components/sections/ArticleList.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

import { companyConfig } from "../../config/company";
import { siteConfig } from "../../config/site";

import {
  generateGraph,
  getOrganization,
  getWebSite,
  getCollectionPage,
  getBreadcrumbs,
} from "../../utils/jsonLD";
import type { Thing } from "schema-dts";

export async function getStaticPaths() {
  const categories = await getCollection("categories");
  return categories.map((cat) => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;

const allArticles = await getCollection("articles");
const articlesInCategory = allArticles.filter(
  (a) => a.data.category?.slug === category.slug,
);

const pageTitle = `${category.data.title} | ${companyConfig.name}`;
const pageDescription =
  category.data.description ??
  `Alla artiklar i kategorin ${category.data.title} från ${companyConfig.name}.`;

const schema = generateGraph([
  getOrganization(),
  getWebSite(),
  getCollectionPage(
    Astro.url.pathname,
    pageTitle,
    pageDescription,
    articlesInCategory.length,
  ) as Thing,
  getBreadcrumbs([
    { name: "Hem", pathname: "/" },
    { name: "Artiklar", pathname: "/artiklar" },
    { name: category.data.title, pathname: Astro.url.pathname },
  ]),
]);
---

<Layout
  title={pageTitle}
  description={pageDescription}
  theme={siteConfig.theme}
  font={siteConfig.font}
  schema={schema}
>
  <Header />

  <main class="flex-grow bg-base-100">
    <header class="py-16 bg-base-200">
      <div class="max-w-[1400px] mx-auto px-4 md:px-10">
        <nav class="text-sm text-base-content/60 mb-6" aria-label="Brödsmulor">
          <a href="/" class="hover:text-primary decoration-0!">Hem</a>
          <span class="mx-2">/</span>
          <a href="/artiklar" class="hover:text-primary decoration-0!">Artiklar</a>
          <span class="mx-2">/</span>
          <span class="text-base-content/80">{category.data.title}</span>
        </nav>

        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-base-content">
          {category.data.title}
        </h1>
        {category.data.description && (
          <p class="text-lg text-base-content/70 max-w-2xl">
            {category.data.description}
          </p>
        )}
        <p class="text-sm text-base-content/50 mt-4">
          {articlesInCategory.length} artiklar
        </p>
      </div>
    </header>

    {articlesInCategory.length === 0 ? (
      <div class="max-w-[1400px] mx-auto px-4 md:px-10 py-16 text-center">
        <p class="text-base-content/60">
          Inga artiklar publicerade i denna kategori ännu.
        </p>
        <a href="/artiklar" class="btn btn-outline mt-6 gap-2 group">
          <Icon
            name="heroicons:chevron-left"
            class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform"
          />
          Tillbaka till alla artiklar
        </a>
      </div>
    ) : (
      <ArticleList category={category.slug} />
    )}
  </main>

  <Footer />
</Layout>
