---
import "../styles/global.css";
import Schema from "../components/seo/Schema.astro";
import CookieConsent from "../components/layout/CookieConsent.astro";
import { ClientRouter } from "astro:transitions";
import type { Graph, Thing } from "schema-dts";
import { companyConfig } from "../config/company";
import { siteConfig } from "../config/site";
import {
  generateGraph,
  getOrganization,
  getWebSite,
  getBlog,
} from "../utils/jsonLD";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  robots?: string;
  font?: "inter" | "dm-sans" | "manrope";
  theme?: string;
  schema?: Graph;
}

const {
  title = "Uppdragsport",
  description,
  image = "/images/hero.webp",
  type = "website",
  robots = "index, follow",
  font = "inter",
  theme = "stadium-noir",
  schema,
} = Astro.props;

const fontClass = {
  inter: "font-inter",
  "dm-sans": "font-dm-sans",
  manrope: "font-manrope",
}[font];

// Normalize: strip trailing slash (root "/" preserved) so canonicals are stable
// regardless of how the page is requested. Matches trailingSlash: 'never' in astro.config.
const normalizedPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const canonicalURL = new URL(normalizedPath, Astro.site).href;
const socialImageURL = new URL(image, Astro.site).href;

// Fallback schema: if a page doesn't pass one in, we emit a sensible
// default tuned to the siteType:
//   service   → Organization + WebSite (primary entity = Organization)
//   content   → Organization + WebSite + Blog (primary entity = Blog)
//   directory → Organization + WebSite (primary entity = WebSite)
let effectiveSchema = schema;
if (!effectiveSchema) {
  const nodes: Thing[] = [getOrganization(), getWebSite()];
  if (siteConfig.siteType === "content") {
    nodes.push(getBlog() as unknown as Thing);
  }
  effectiveSchema = generateGraph(nodes);
}
---

<!doctype html>
<html lang="sv" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="robots" content={robots} />
    {description && <meta name="description" content={description} />}

    <!-- Open Graph / Facebook -->
    <meta property="og:locale" content="sv_SE" />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:site_name" content={companyConfig.name} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={socialImageURL} />

    {effectiveSchema && <Schema graph={effectiveSchema} />}

    <!-- RSS-feed (länkar fram även för service-sajter; ofarligt om feed:en är tom) -->
    <link rel="alternate" type="application/rss+xml" title={companyConfig.name} href="/rss.xml" />

    <!-- App-känsla mellan sidor (Astro View Transitions) -->
    <ClientRouter />
  </head>
  <body class={`min-h-screen flex flex-col ${fontClass}`}>
    <slot />
    <CookieConsent />

    <script>
      import Lenis from "lenis";
      import { animate, inView, stagger } from "motion";

      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      // CSS döljer stagger-barn endast när JS är aktivt (annars syns allt).
      document.documentElement.classList.add("js-motion");

      // Lenis smooth scroll — initieras EN gång och överlever view transitions.
      function initLenis() {
        if (reduce || (window as any).__lenis) return;
        const lenis = new Lenis({ duration: 1.1, smoothWheel: true });
        (window as any).__lenis = lenis;
        const raf = (t: number) => { lenis.raf(t); requestAnimationFrame(raf); };
        requestAnimationFrame(raf);
      }

      // Scroll-reveal (.reveal) — binär fade (threshold 0 undviker blank-fällan).
      function initReveal() {
        const els = document.querySelectorAll<HTMLElement>(".reveal:not(.is-visible)");
        if (!els.length) return;
        if (reduce) { els.forEach((el) => el.classList.add("is-visible")); return; }
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("is-visible"); io.unobserve(e.target); } });
        }, { threshold: 0, rootMargin: "0px 0px -12% 0px" });
        els.forEach((el) => io.observe(el));
      }

      // Count-up: siffror ([data-countup]) räknas upp från 0 när de syns.
      function initCountUp() {
        document.querySelectorAll<HTMLElement>("[data-countup]:not([data-done])").forEach((el) => {
          const target = parseFloat((el.dataset.countup || "").replace(",", "."));
          el.dataset.done = "1";
          if (!isFinite(target) || reduce) return;
          const dec = (el.dataset.countup || "").includes(",") ? 1 : 0;
          inView(el, () => {
            animate(0, target, {
              duration: 1.1, ease: [0.16, 1, 0.3, 1],
              onUpdate: (v) => { el.textContent = dec ? v.toFixed(dec).replace(".", ",") : Math.round(v).toString(); },
            });
          }, { amount: 0.6 });
        });
      }

      // Staggrade reveals: barn i .stagger-group glider in i sekvens.
      function initStagger() {
        document.querySelectorAll<HTMLElement>(".stagger-group:not([data-done])").forEach((group) => {
          group.dataset.done = "1";
          const kids = Array.from(group.children) as HTMLElement[];
          if (reduce) { kids.forEach((k) => (k.style.opacity = "1")); return; }
          inView(group, () => {
            animate(kids, { opacity: [0, 1], transform: ["translateY(22px)", "translateY(0)"] },
              { duration: 0.7, delay: stagger(0.06), ease: [0.16, 1, 0.3, 1] });
          }, { amount: 0.12 });
        });
      }

      // Streck-/progress-barer ([data-bar]=procent) fylls på plats.
      function initBars() {
        document.querySelectorAll<HTMLElement>("[data-bar]:not([data-done])").forEach((el) => {
          el.dataset.done = "1";
          const w = parseFloat(el.dataset.bar || "0");
          if (reduce) { el.style.width = w + "%"; return; }
          el.style.width = "0%";
          inView(el, () => { animate(el, { width: ["0%", w + "%"] }, { duration: 0.9, ease: [0.16, 1, 0.3, 1] }); }, { amount: 0.4 });
        });
      }

      function initAll() { initLenis(); initReveal(); initCountUp(); initStagger(); initBars(); }
      // astro:page-load fyrar på första laddningen OCH efter varje view transition.
      document.addEventListener("astro:page-load", initAll);
      // ClientRouter nollställer <html>-klasserna vid navigering → återställ
      // js-motion FÖRE paint så stagger-barnen inte blinkar till.
      document.addEventListener("astro:after-swap", () => document.documentElement.classList.add("js-motion"));
    </script>
  </body>
</html>
