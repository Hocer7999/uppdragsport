---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  title?: string;
  stats?: Stat[];
}

const {
  title = "Siffror som talar för sig själva",
  stats = [
    { value: "TODO", label: "TODO" },
    { value: "TODO", label: "TODO" },
    { value: "TODO", label: "TODO" },
    { value: "TODO", label: "TODO" },
  ],
} = Astro.props;
---

<section class="bg-primary py-16 text-primary-content">
  <div class="max-w-[1400px] mx-auto px-4 md:px-10">
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-12">
      {title}
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        stats.map((stat) => (
          <div class="bg-primary-content/10 border border-primary-content/20 rounded-xl p-8 text-center backdrop-blur-sm">
            <h3 class="text-3xl md:text-4xl font-bold mb-3">{stat.value}</h3>
            <p class="text-sm md:text-base opacity-80">{stat.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
