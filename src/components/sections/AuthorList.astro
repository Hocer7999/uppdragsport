---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";

interface Props {
  title?: string;
  description?: string;
  /** Truncate bios to this length on the listing view. */
  bioMaxLength?: number;
}

const {
  title = "Våra skribenter",
  description = "Möt redaktionen bakom artiklarna.",
  bioMaxLength = 160,
} = Astro.props;

const authors = await getCollection("authors");

function truncate(str: string, max: number): string {
  if (str.length <= max) return str;
  return str.slice(0, max).trimEnd() + "…";
}
---

<section class="section-pad bg-base-100">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10">
    <div class="mb-12 max-w-2xl">
      <p class="micro-label mb-5">Redaktionen</p>
      {title && (
        <h2 class="font-display text-5xl md:text-7xl text-white tracking-[-0.045em] mb-5">
          {title}
        </h2>
      )}
      {description && (
        <p class="text-white/55 text-lg leading-relaxed">{description}</p>
      )}
    </div>

    {authors.length === 0 ? (
      <p class="text-white/40">
        Lägg till markdown-filer i <code>src/content/authors/</code> för att
        fylla detta automatiskt.
      </p>
    ) : (
      <div class="divide-y divide-white/10 border-y border-white/10">
        {authors.map((author) => (
          <a
            href={`/forfattare/${author.slug}`}
            class="group flex items-center gap-5 md:gap-8 py-7 decoration-0!"
          >
            {author.data.avatar ? (
              <img
                src={author.data.avatar}
                alt={author.data.name}
                class="w-16 h-16 md:w-20 md:h-20 rounded-full object-cover flex-shrink-0 grayscale group-hover:grayscale-0 transition-all duration-500"
              />
            ) : (
              <div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-base-200 text-white/40 flex items-center justify-center flex-shrink-0">
                <Icon name="heroicons:user" class="w-8 h-8" />
              </div>
            )}
            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-1.5">
                <h3 class="font-display text-2xl md:text-3xl text-white tracking-[-0.035em]">
                  {author.data.name}
                </h3>
                {author.data.role && (
                  <span class="micro-label">{author.data.role}</span>
                )}
              </div>
              <p class="text-white/50 leading-relaxed max-w-2xl">
                {truncate(author.data.bio, bioMaxLength)}
              </p>
            </div>
            <Icon
              name="heroicons:arrow-right"
              class="w-5 h-5 text-white/30 group-hover:text-primary flex-shrink-0 transition-colors hidden sm:block"
            />
          </a>
        ))}
      </div>
    )}
  </div>
</section>
