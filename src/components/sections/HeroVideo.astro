---
import { Icon } from "astro-icon/components";

interface CTA {
  text: string;
  href: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  videoSrc?: string;
  videoType?: string;
  poster?: string;
  fallbackImage?: string;
  primaryCta?: CTA;
  secondaryCta?: CTA;
}

const {
  title = "Välkommen",
  subtitle = "En kort, tydlig presentation av er verksamhet. Anpassa rubriken och underrubriken efter ert företag.",
  videoSrc,
  videoType = "video/mp4",
  poster = "https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1600&q=80",
  fallbackImage = "https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1600&q=80",
  primaryCta,
  secondaryCta,
} = Astro.props;
---

<section
  class="relative py-32 md:py-48 flex items-center justify-center text-center px-4 overflow-hidden bg-base-300"
>
  <!-- Video Background with reduced-motion fallback -->
  <div class="absolute inset-0 z-0">
    <div
      class="absolute inset-0 z-10 bg-gradient-to-b from-black/50 to-black/70"
    >
    </div>

    {videoSrc ? (
      <>
        <video
          autoplay
          muted
          loop
          playsinline
          poster={poster}
          class="w-full h-full object-cover motion-reduce:hidden"
        >
          <source src={videoSrc} type={videoType} />
        </video>
        <img
          src={fallbackImage}
          alt=""
          class="hidden motion-reduce:block w-full h-full object-cover"
        />
      </>
    ) : (
      <img src={fallbackImage} alt="" class="w-full h-full object-cover" />
    )}
  </div>

  <div class="relative z-10 max-w-4xl mx-auto flex flex-col items-center">
    <h1
      class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-white mb-6 leading-[1.1] tracking-tight text-shadow-lg"
    >
      {title}
    </h1>

    <p
      class="text-lg md:text-xl text-white/90 mb-10 max-w-2xl leading-relaxed text-shadow-sm font-medium"
    >
      {subtitle}
    </p>

    {(primaryCta || secondaryCta) && (
      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
        {primaryCta && (
          <a
            href={primaryCta.href}
            class="btn btn-primary btn-lg rounded-full px-8 shadow-xl hover:scale-105 transition-transform gap-2"
          >
            {primaryCta.text}
            <Icon name="heroicons:arrow-right" class="w-4 h-4" />
          </a>
        )}
        {secondaryCta && (
          <a
            href={secondaryCta.href}
            class="btn btn-neutral btn-lg rounded-full px-8 bg-white text-base-content border-white hover:bg-base-200 hover:border-base-200 hover:scale-105 transition-transform"
          >
            {secondaryCta.text}
          </a>
        )}
      </div>
    )}
  </div>
</section>

<style>
  .text-shadow-lg {
    text-shadow:
      0 4px 20px rgba(0, 0, 0, 0.5),
      0 2px 8px rgba(0, 0, 0, 0.3);
  }
  .text-shadow-sm {
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }
</style>
