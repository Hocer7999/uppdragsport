---
import { companyConfig } from "../../config/company";

interface Stat {
  value: string;
  label: string;
}

interface Props {
  eyebrow?: string;
  stats?: Stat[];
}

const {
  eyebrow = "Det här gör vi bra",
  stats = companyConfig.stats,
} = Astro.props;
---

<section class="bg-primary py-16">
    <div class="max-w-[1000px] mx-auto px-4 md:px-10">
        <p
            class="text-center text-primary-content/90 font-medium mb-10 text-lg"
        >
            {eyebrow}
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 text-center">
            {
                stats.map((stat) => (
                    <div>
                        <h3 class="text-4xl lg:text-5xl font-bold text-primary-content mb-2">
                            {stat.value}
                        </h3>
                        <p class="text-sm lg:text-base text-primary-content/70">
                            {stat.label}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
