---
import { Icon } from "astro-icon/components";

interface Props {
  title?: string;
  description?: string;
  cardTitle?: string;
  cardDescription?: string;
  cardIcon?: string;
  ctaText?: string;
  ctaLink?: string;
}

const {
  title = "Håll dig i matchen",
  description = "Få veckans bästa analyser och reportage direkt i inkorgen.",
  cardTitle = "Nyhetsbrevet",
  cardDescription = "Ett mejl i veckan. Bara sport, ingen reklam.",
  cardIcon = "heroicons:bolt",
  ctaText = "Prenumerera",
  ctaLink = "/#nyhetsbrev",
} = Astro.props;
---

<section class="relative isolate overflow-hidden bg-base-200 section-pad">
  <!-- Diskret röd halo (enda röda momentet i sektionen utöver knappen) -->
  <div class="halo-red pointer-events-none absolute inset-0 -z-0 opacity-60"></div>

  <div
    class="relative z-10 max-w-[1400px] mx-auto px-6 md:px-10 grid lg:grid-cols-[1.3fr_1fr] gap-12 lg:gap-20 items-center"
  >
    <div>
      <p class="micro-label mb-6">Uppdragsport</p>
      <h2 class="font-display text-5xl md:text-7xl text-white tracking-[-0.045em] leading-[0.95] mb-5">
        {title}
      </h2>
      <p class="text-white/55 text-lg leading-relaxed max-w-xl">
        {description}
      </p>
    </div>

    <div class="border-t border-white/10 pt-8">
      <div class="w-11 h-11 text-primary mb-5">
        <Icon name={cardIcon} class="w-full h-full" />
      </div>
      <h3 class="font-display text-2xl text-white tracking-[-0.035em] mb-2">{cardTitle}</h3>
      <p class="text-white/50 mb-7 leading-relaxed">
        {cardDescription}
      </p>
      <a
        href={ctaLink}
        class="btn btn-primary rounded-field px-7 border-0 decoration-0! gap-2"
      >
        {ctaText}
        <Icon name="heroicons:arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </div>
</section>
