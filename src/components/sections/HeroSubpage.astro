---
interface Props {
  title: string;
  description?: string;
  backgroundImage?: string;
  primaryCta?: string;
  primaryCtaLink?: string;
  secondaryCta?: string;
  secondaryCtaLink?: string;
}

const {
  title,
  description,
  backgroundImage = "https://images.unsplash.com/photo-1449965408869-eaa3f722e40d?w=1600&q=80",
  primaryCta,
  primaryCtaLink = "#",
  secondaryCta,
  secondaryCtaLink = "#",
} = Astro.props;

const hasButtons = primaryCta || secondaryCta;
---

<section 
  class="relative py-32 md:py-48 flex items-center justify-center text-center px-4 overflow-hidden bg-base-300"
>
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-base-900/60 z-10 bg-gradient-to-b from-black/50 to-black/70"></div>
    <img 
      src={backgroundImage} 
      alt="" 
      class="w-full h-full object-cover"
    />
  </div>

  <div class="relative z-10 max-w-4xl mx-auto flex flex-col items-center">
    
    <h1 class="font-display text-5xl md:text-7xl lg:text-8xl text-white mb-6 leading-[0.95] tracking-[-0.045em] text-shadow-lg">
      {title}
    </h1>

    {description && (
      <p class="text-lg md:text-xl text-white/90 mb-10 max-w-2xl leading-relaxed text-shadow-sm font-medium">
        {description}
      </p>
    )}

    {hasButtons && (
      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto mt-2">
        {primaryCta && (
          <a 
            href={primaryCtaLink} 
            class="btn btn-primary btn-lg rounded-full px-8 shadow-xl hover:scale-105 transition-transform"
          >
            {primaryCta}
          </a>
        )}
        
        {secondaryCta && (
          <a 
            href={secondaryCtaLink} 
            class="btn btn-neutral btn-lg rounded-full px-8 bg-white text-base-content border-white hover:bg-base-200 hover:border-base-200 hover:scale-105 transition-transform"
          >
            {secondaryCta}
          </a>
        )}
      </div>
    )}
  </div>
</section>

<style>
  .text-shadow-lg {
    text-shadow: 0 4px 20px rgba(0,0,0,0.5), 0 2px 8px rgba(0,0,0,0.3);
  }
  .text-shadow-sm {
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
  }
</style>
