---
// Annons-banner. Med `image` (fal-genererad creative) + `brand` visas en
// betting-/casino-annons (icke-klickbar — bara för känslan). Utan `image`
// visas en ren "Annons"-platshållare. variant: "leaderboard" | "rectangle".
// OBS: varumärkesnamnen är mockups för känslan — byt mot riktig annonskod
// eller egna house-promos före skarp lansering (varumärkesskäl).
interface Props {
  variant?: "leaderboard" | "rectangle";
  label?: string;
  image?: string;
  brand?: string;
  accent?: string;
  tagline?: string;
  cta?: string;
}
const {
  variant = "leaderboard",
  label = "Annons",
  image,
  brand,
  accent = "#f33736",
  tagline,
  cta = "Spela nu",
} = Astro.props;
const isLeader = variant === "leaderboard";
const branded = !!(image && brand);
---

{isLeader ? (
  <section class="bg-base-100 py-6">
    <div class="max-w-[1400px] mx-auto px-6 md:px-10">
      {branded ? (
        <div class="relative overflow-hidden rounded-box border border-white/10 h-28 md:h-32" aria-label={`Annons: ${brand}`}>
          <img src={image} alt="" class="absolute inset-0 w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/45 to-transparent"></div>
          <span class="absolute top-2.5 left-3 micro-label text-white/40 z-10">{label}</span>
          <div class="relative z-10 h-full flex items-center justify-between gap-4 px-6 md:px-8">
            <div>
              <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-[3px]" style={`background:${accent}`}></span>
                <span class="font-display text-2xl md:text-3xl font-bold text-white tracking-[-0.02em]">{brand}</span>
              </div>
              {tagline && <p class="text-white/70 text-sm mt-1 max-w-md">{tagline}</p>}
            </div>
            <span class="shrink-0 px-4 py-2 rounded-field text-sm font-bold text-black" style={`background:${accent}`}>{cta}</span>
          </div>
          <span class="absolute bottom-2 right-3 z-10 text-[0.5rem] text-white/45 tracking-wide">18+ · Spela ansvarsfullt</span>
        </div>
      ) : (
        <div class="relative flex items-center justify-center rounded-box bg-base-200/60 border border-dashed border-white/10 h-24 md:h-28 text-center" role="complementary" aria-label="Annonsplats">
          <span class="absolute top-2.5 left-3 micro-label text-white/25">{label}</span>
          <div class="text-white/20">
            <p class="micro-label">Annonsplats</p>
            <p class="text-xs mt-1 tracking-wider">970 × 90</p>
          </div>
        </div>
      )}
    </div>
  </section>
) : (
  branded ? (
    <div class="relative overflow-hidden rounded-box border border-white/10 aspect-[300/250]" aria-label={`Annons: ${brand}`}>
      <img src={image} alt="" class="absolute inset-0 w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/35 to-black/20"></div>
      <span class="absolute top-2.5 left-3 micro-label text-white/40 z-10">{label}</span>
      <div class="absolute inset-x-0 bottom-0 p-5 z-10">
        <div class="flex items-center gap-2 mb-1">
          <span class="w-2.5 h-2.5 rounded-[3px]" style={`background:${accent}`}></span>
          <span class="font-display text-2xl font-bold text-white tracking-[-0.02em]">{brand}</span>
        </div>
        {tagline && <p class="text-white/70 text-sm mb-3">{tagline}</p>}
        <span class="inline-block px-4 py-2 rounded-field text-sm font-bold text-black" style={`background:${accent}`}>{cta}</span>
        <p class="text-[0.5rem] text-white/45 mt-2.5 tracking-wide">18+ · Spela ansvarsfullt · stodlinjen.se</p>
      </div>
    </div>
  ) : (
    <div class="relative flex items-center justify-center rounded-box bg-base-200/60 border border-dashed border-white/10 aspect-[300/250] text-center" role="complementary" aria-label="Annonsplats">
      <span class="absolute top-2.5 left-3 micro-label text-white/25">{label}</span>
      <div class="text-white/20">
        <p class="micro-label">Annonsplats</p>
        <p class="text-xs mt-1 tracking-wider">300 × 250</p>
      </div>
    </div>
  )
)}
