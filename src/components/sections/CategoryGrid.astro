---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Kategorier",
  description = "Bläddra efter ämne — välj en kategori för att se alla artiklar.",
} = Astro.props;

const categories = (await getCollection("categories")).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0),
);

// Count articles per category for display
const allArticles = await getCollection("articles");
const counts: Record<string, number> = {};
for (const cat of categories) {
  counts[cat.slug] = allArticles.filter(
    (a) => (a.data.category?.id ?? a.data.category?.slug) === cat.slug,
  ).length;
}
---

<section id="kategorier" class="section-pad bg-base-100">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10">
    <div class="mb-14 max-w-2xl">
      <p class="micro-label mb-5">Bevakning</p>
      {title && (
        <h2 class="font-display text-5xl md:text-7xl text-white tracking-[-0.045em] mb-5">
          {title}
        </h2>
      )}
      {description && (
        <p class="text-white/55 text-lg leading-relaxed">{description}</p>
      )}
    </div>

    {categories.length === 0 ? (
      <p class="text-white/40">
        Lägg till markdown-filer i <code>src/content/categories/</code> för att
        fylla detta rutnät automatiskt.
      </p>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10">
        {categories.map((cat, i) => (
          <a
            href={`/kategori/${cat.slug}`}
            class="group block decoration-0!"
          >
            <div class="relative aspect-[4/5] overflow-hidden rounded-box bg-base-200">
              {cat.data.image && (
                <img
                  src={cat.data.image}
                  alt={cat.data.title}
                  class="absolute inset-0 w-full h-full object-cover opacity-70 transition-all duration-700 group-hover:opacity-90 group-hover:scale-105"
                />
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/30 to-transparent"></div>
              <span class="absolute top-5 left-5 font-display text-white/35 text-2xl tabular-nums">
                {String(i + 1).padStart(2, "0")}
              </span>
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <h3 class="font-display text-3xl md:text-4xl text-white tracking-[-0.04em] mb-1">
                  {cat.data.title}
                </h3>
                <div class="flex items-center justify-between">
                  <span class="micro-label">{counts[cat.slug] ?? 0} artiklar</span>
                  <span class="text-white/60 group-hover:text-primary inline-flex items-center gap-1 group-hover:gap-2 transition-all">
                    <Icon name="heroicons:arrow-right" class="w-5 h-5" />
                  </span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>
