---
import { type Package, defaultPackages } from "../../config/pricing";

interface Props {
  title?: string;
  description?: string;
  packages?: Package[];
}

const {
  title = "Våra paket",
  description = "Välj det paket som passar er bäst. Skalbara lösningar för företag av alla storlekar.",
  packages = defaultPackages,
} = Astro.props;

import { Icon } from "astro-icon/components";
---

<section class="py-20 bg-base-100" id="priser">
  <div class="max-w-[1400px] mx-auto px-4 md:px-10">
    <div class="text-center mb-12 max-w-2xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-base-content">
        {title}
      </h2>
      <p class="text-lg text-base-content/70">{description}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        packages.map((pkg) => (
          <div
            class={`rounded-2xl p-8 relative flex flex-col h-full bg-base-100 ${
              pkg.isFeatured
                ? "border-4 border-primary shadow-xl"
                : "border-2 border-base-200 hover:border-base-300 transition-colors"
            }`}
          >
            {pkg.badge && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1.5 bg-primary text-primary-content text-xs font-bold uppercase tracking-wider rounded-full shadow-lg">
                {pkg.badge}
              </div>
            )}

            <h3 class="text-2xl font-bold mb-2 text-base-content">
              {pkg.name}
            </h3>
            <p class="text-sm text-base-content/60 mb-6">{pkg.subtitle}</p>

            <div class="mb-6">
              <div class="flex items-baseline gap-2">
                <span class="text-4xl font-extrabold text-base-content">
                  {pkg.price}
                </span>
              </div>
              {pkg.originalPrice && (
                <span class="text-lg text-base-content/40 line-through block mt-1">
                  {pkg.originalPrice}
                </span>
              )}
            </div>

            <ul class="space-y-4 mb-8 flex-1">
              {pkg.features.map((feature) => (
                <li class="flex items-start gap-3 text-base-content/80 text-sm">
                  <div class="w-5 h-5 rounded-full bg-success/20 flex items-center justify-center shrink-0 mt-0.5">
                    <Icon name="heroicons:check" class="w-3 h-3 text-success" />
                  </div>
                  <span>{feature.text}</span>
                </li>
              ))}
            </ul>

            <button
              class={`w-full py-4 px-6 rounded-full font-bold text-sm uppercase tracking-wide transition-all transform active:scale-95 ${
                pkg.isFeatured
                  ? "bg-primary text-primary-content hover:bg-primary-focus hover:-translate-y-1 shadow-md hover:shadow-lg"
                  : "bg-base-content text-base-100 hover:bg-base-content/90 hover:-translate-y-1"
              }`}
            >
              {pkg.ctaText}
            </button>
          </div>
        ))
      }
    </div>
  </div>
</section>
